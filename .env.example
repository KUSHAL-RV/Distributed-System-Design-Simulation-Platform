# PostgreSQL
POSTGRES_USER=livesys
POSTGRES_PASSWORD=livesys_secret_2024
POSTGRES_DB=livesysdesign
DATABASE_URL=postgresql://livesys:livesys_secret_2024@localhost:5432/livesysdesign

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# Gateway (Node.js)
GATEWAY_PORT=4000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000

# Sim Engine (Go)
SIM_ENGINE_PORT=5000
SIM_ENGINE_GRPC_PORT=5000

# Metrics Service (Go)
METRICS_SVC_PORT=5001

# AI Service (Python)
AI_SVC_PORT=6000
